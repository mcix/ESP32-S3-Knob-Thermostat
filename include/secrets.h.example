#ifndef SECRETS_H
#define SECRETS_H

// ============================================
// WiFi Configuration
// ============================================
#define WIFI_SSID          "your-wifi-ssid"
#define WIFI_PASSWORD      "your-wifi-password"

// ============================================
// Homey Pro Configuration
// ============================================
// Your Homey Pro's local IP address (e.g., "192.168.1.100")
#define HOMEY_IP           "192.168.x.x"

// API Key from Homey App -> Settings -> API Keys
#define HOMEY_API_KEY      "your-homey-api-key"

// Plugwise thermostat device ID from Homey
// Find this via: http://<HOMEY_IP>/api/manager/devices/device/
#define THERMOSTAT_DEVICE_ID "your-thermostat-device-id"

#endif // SECRETS_H
